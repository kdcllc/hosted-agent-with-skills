# Local development settings
FOUNDRY_PROJECT_ENDPOINT=https://<your-account>.services.ai.azure.com/api/projects/<your-project>
FOUNDRY_MODEL_DEPLOYMENT_NAME=gpt-5.4-mini

# Existing Azure Container Registry (no protocol, no repository)
AZURE_CONTAINER_REGISTRY_NAME=<your-acr-name>
IMAGE_REPOSITORY=blog-writer-agent
IMAGE_TAG=<yyyymmddhhmmss>

# Optional explicit deployment name override
AGENT_NAME=blog-writer-agent

# Optional: set to true when running in hosted environment if you extend auth handling later
USE_MANAGED_IDENTITY=false
